# infra/terraform/.env (gitignored)
# Source: docs/decisions/0001-iac-terraform.md §secret 管理
#
# Terraform variables (TF_VAR_* prefix is auto-stripped by Terraform)

# Cloudflare API token with scopes:
#   AI Search:Edit + Read + Run + Index, R2:Edit, Workers Scripts:Edit,
#   Access (Apps and Policies + IdP/Groups + Service Tokens):Edit, AI Gateway:Edit
# Get one from: https://dash.cloudflare.com -> My Profile -> API Tokens
TF_VAR_cloudflare_api_token=

# UUID (32-char hex) of the above token. Look up with:
#   curl -s -H "Authorization: Bearer $TF_VAR_cloudflare_api_token" \
#     https://api.cloudflare.com/client/v4/user/tokens/verify | jq -r '.result.id'
# This is required by cloudflare_ai_search_token.cf_api_id
# (registers the token as the credential AI Search uses to read R2).
TF_VAR_cloudflare_api_token_id=

# Non-secret 設定 (account_id / OTP domain / operator email / workers.dev subdomain
# / prefix) は ../../instance.config.yaml に集約 (spec ADR 0002 §3.2 #3)。
# 旧 TF_VAR_cloudflare_account_id / otp_email_domain / operator_email /
# workers_dev_subdomain は廃止 (variables.tf からも削除)。
